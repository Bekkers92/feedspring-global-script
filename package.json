{
  "name": "feedspring-site-engine",
  "version": "0.1.2",
  "description": "SSE site package for FeedSpring Webflow custom code.",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "serve": "serve",
    "build": "node build.js",
    "build:prod": "node build.js && npm run minify",
    "watch": "node build.js --watch",
    "minify": "esbuild dist/index.js --minify --sourcemap --outfile=dist/index.js --allow-overwrite",
    "generate:routes": "node generate-imports.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier src/**/*.{ts,scss} -w",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": {
    "name": "Michael Wells",
    "email": "mike@sygnal.com",
    "url": "https://www.sygnal.com"
  },
  "license": "",
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "devDependencies": {
    "esbuild": "^0.15.14",
    "prettier": "^2.7.1",
    "sass": "^1.93.2",
    "serve": "^14.1.1",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "@sygnal/sse-core": "^2.1.2",
    "glob": "^10.4.2",
    "gsap": "^3.12.5",
    "js-cookie": "^3.0.5"
  }
}
